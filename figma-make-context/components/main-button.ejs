/**
 * Main Button Component
 * 
 * @param {string} [text=''] - Button text
 * @param {string} [style='solid'] - 'solid' | 'outline' | 'ghost' | 'icon'
 * @param {string} [color='primary'] - 'primary' | 'neutral-dark' | 'neutral-medium' | 'neutral-light' | 'error' | 'warning'
 * @param {boolean} [disabled=false] - Whether the button is disabled
 * @param {boolean} [loading=false] - Whether the button is in loading state
 * @param {string} [icon=''] - SVG path or icon name (optional)
 * @param {string} [iconPosition='left'] - 'left' | 'right' | 'only' (only used if icon is provided)
 * @param {string} [className=''] - Additional CSS classes to override defaults
 * @param {string} [id=''] - ID for the button element
 * @param {object} [handlers={}] - Event handlers (e.g., { click: 'handleButtonClick' })
 * @param {object} [dataTags={}] - Data attributes to add to the button
 * 
 * TAILWIND JIT: Dynamic hover classes used by this component
 * (Tailwind scans comments to detect classes for JIT compilation)
 * 
 * hover:bg-surface-secondary hover:bg-brand-green_light-50 hover:bg-alias-neutral-400
 * hover:bg-alias-neutral-200 hover:bg-alias-neutral-o0_20 hover:bg-surface-error
 * hover:bg-surface-error_focus hover:bg-alias-error-50 hover:bg-surface-warning
 * hover:bg-surface-warning_focus hover:bg-brand-orange-100 hover:bg-surface-info
 * hover:bg-surface-info_focus hover:bg-alias-info-100 hover:!border-[0px]
 * 
 * hover:[box-shadow:inset_0px_0px_35px_0px_var(--alias-secondary-100)]
 * hover:[box-shadow:inset_0px_0px_35px_0px_var(--alias-error-400)]
 * hover:[box-shadow:inset_0px_0px_35px_0px_var(--mapped-surface-warning)]
 * hover:[box-shadow:inset_0px_0px_35px_0px_var(--alias-info-300)]
 * 
 * border-text-success border-text-primary border-text-tertiary
 * border-text-error border-text-warning border-text-info
 */

