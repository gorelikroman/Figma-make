// Get current color/style configuration
const currentConfig = colorConfig[props.color] && colorConfig[props.color][props.style] 
  ? colorConfig[props.color][props.style] 
  : colorConfig.primary.solid;

const idleState = currentConfig.idle;
const focusState = currentConfig.focus;
const disabledState = currentConfig.disabled;

// Determine if we need overlay for gradient transitions
const needsOverlay = !props.disabled && idleState.background && idleState.background.includes('gradient') && focusState.background;
let overlayBgColor = '';
if (needsOverlay) {
  // Extract color from Tailwind class or hex value
  if (focusState.background.includes('secondary') || focusState.background.includes('surface-secondary')) {
    overlayBgColor = '#61a333'; // secondary-500 / surface-secondary value
  } else if (focusState.background.includes('error-500')) {
    overlayBgColor = '#cc0000'; // error-500 value
  } else if (focusState.background.includes('error-400')) {
    overlayBgColor = '#e36959'; // error-400 value
  } else if (focusState.background.includes('warning-500')) {
    overlayBgColor = '#f08e00'; // warning-500 value
  } else if (focusState.background.includes('info-500')) {
    overlayBgColor = '#257db0'; // info-500 value
  } else {
    // Fallback: try to extract hex value
    const colorMatch = focusState.background.match(/#[0-9A-Fa-f]{6}/i);
    if (colorMatch) {
      overlayBgColor = colorMatch[0];
    }
  }
}

// Build base classes
let baseClasses = `font-header flex items-center justify-center font-medium transition-all duration-300 ${currentSize.borderRadius}`;
// Add faster border transition via style attribute if border changes on hover
let borderTransitionStyle = '';
if (!props.disabled && idleState.border && !focusState.border) {
  borderTransitionStyle = 'transition: border-width 100ms ease-in-out, background-color 300ms ease-in-out, color 300ms ease-in-out, box-shadow 300ms ease-in-out;';
}
baseClasses += ` ${currentSize.fontSize}`;
baseClasses += ' leading-none';
baseClasses += ` ${currentSize.paddingH} ${currentSize.paddingV}`;

// Width/Height removed - use Tailwind classes via class prop

// State classes - put text color last for higher specificity
let stateClasses = '';
if (props.disabled) {
  stateClasses = `${disabledState.background} ${disabledState.border} ${disabledState.shadow} ${disabledState.textColor} cursor-not-allowed`;
} else {
  stateClasses = `${idleState.background} ${idleState.border} ${idleState.shadow} ${idleState.textColor}`;
  
  // Add hover/focus classes
  if (focusState.background && !needsOverlay) {
    stateClasses += ` hover:${focusState.background}`;
  }
  if (focusState.border) {
    stateClasses += ` hover:${focusState.border}`;
  } else if (idleState.border) {
    // If focus border is empty but idle has border, remove it on hover
    stateClasses += ' hover:!border-[0px]';
  }
  if (focusState.shadow) {
    stateClasses += ` hover:${focusState.shadow}`;
  }
  // Note: text color is handled via group-hover on the inner span, not here
  
  // Add group class for overlay and text color transitions
  if (needsOverlay || (focusState.textColor && focusState.textColor !== idleState.textColor)) {
    baseClasses += ' group';
  }
}

// Underline for ghost style is applied to the text span, not the button

// Combine all classes - props.className appended at end to override defaults
let allClasses = `${baseClasses} ${stateClasses} relative overflow-hidden ${props.className}`.trim().replace(/\s+/g, ' ');
%>
<%
// Generate data attributes string
let dataAttributes = '';

// Add custom data tags
for (const [key, value] of Object.entries(props.dataTags)) {
    dataAttributes += ` data-${key}="${value}"`;
}

// Add handler attributes (data-onclick, etc.)
for (const [eventType, handlerName] of Object.entries(props.handlers)) {
    if (handlerName) {
        dataAttributes += ` data-on${eventType}="${handlerName}"`;
    }
}
%>
<button 
    <% if (props.id) { %>id="<%= props.id %>"<% } %>
    class="<%= allClasses %>"
    <%= props.disabled ? 'disabled' : '' %>
    <%- dataAttributes %>
    <% if (needsOverlay && overlayBgColor && !props.disabled) { %>
    style="--hover-overlay-color: <%= overlayBgColor %>;<% if (borderTransitionStyle) { %> <%= borderTransitionStyle %><% } %>"
    <% } else if (borderTransitionStyle) { %>
    style="<%= borderTransitionStyle %>"
    <% } %>
>
    <% if (needsOverlay && overlayBgColor && !props.disabled) { %>
    <!-- Overlay for smooth gradient to solid transition -->
    <span class="absolute inset-0 bg-[var(--hover-overlay-color)] opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none <%= currentSize.borderRadius %> <%= focusState.shadow ? focusState.shadow.replace('hover:', '') : '' %>"></span>
    <% } %>
    
    <span class="relative z-10 flex items-center justify-center <%= props.disabled ? disabledState.textColor : idleState.textColor %><% if (!props.disabled && focusState.textColor && focusState.textColor !== idleState.textColor) { %> group-hover:!<%= focusState.textColor %><% } %>">
        <span class="<%= props.disabled ? disabledState.textColor : idleState.textColor %><% if (!props.disabled && focusState.textColor && focusState.textColor !== idleState.textColor) { %> group-hover:!<%= focusState.textColor %><% } %><% if (props.style === 'ghost' && ((props.disabled && disabledState.underline) || (!props.disabled && idleState.underline))) { %> <%= props.disabled ? disabledState.underline : idleState.underline %><% } %>"><%= props.text %></span>
    </span>
</button>
